{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Gnome Data Stats",
  "version": "0.3.1",
  "identifier": "com.tohju.gnome-data-stats",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Gnome Data Stats",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "sql": {
      "preload": [
        "sqlite:stats.db"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "shortDescription": "Gnome Data Stats network monitor",
    "longDescription": "A modern, lightweight network data usage monitor for GNOME and other Linux desktops. Track real-time speeds, session totals, and daily history with a native-feeling Adwaita interface."
  }
}